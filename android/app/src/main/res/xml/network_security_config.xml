<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许所有域名使用明文HTTP流量（仅用于开发/测试，生产环境应使用HTTPS） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
